# =====================================================================
# @file .gitignore
# @description Listado de exclusiones de Git para el proyecto Stackupia.
# @author Gerardo Paiva G.
# @date 18-07-2026
# 
# HISTORIAL DE CAMBIOS:
# Version | Fecha      | Autor            | Descripción
# V1.0.0  | 18-07-2026 | Gerardo Paiva G. | Exclusiones iniciales de dependencias, entornos, caches y temporales.
# =====================================================================

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Environment / Keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Docker volume caches
.docker-data/

# OS / IDE
.DS_Store
Thumbs.db
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# Temp/Logs
*.log
logs/
temp/
tmp/
